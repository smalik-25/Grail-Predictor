# Copy to .env and fill in. Everything runs on fixtures without this file.

# Live network access is opt-in. Without this, every source stays in
# fixture mode even if credentials are present.
INGEST_LIVE=0

# Grailed search runs on Algolia; these are the values Grailed's own frontend
# uses. They rotate, which is why they live here and not in code.
GRAILED_ALGOLIA_APP_ID=your-app-id
GRAILED_ALGOLIA_API_KEY=your-search-key

# Bright Data (used surgically where free access is not realistic)
BRIGHTDATA_API_KEY=your-key-here
BRIGHTDATA_ZONE=your-zone-here

# Reddit (PRAW), used by ingestion/social.py
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USER_AGENT=grail-predictor/0.1 by your-reddit-username

# eBay Browse API (client-credentials OAuth), used by ingestion/ebay.py
EBAY_APP_ID=your-app-id
EBAY_CERT_ID=your-cert-id
